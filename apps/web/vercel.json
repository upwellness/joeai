{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "pnpm install --frozen-lockfile=false",
  "outputDirectory": ".next",
  "functions": {
    "src/app/api/jobs/**/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/webhook/line/route.ts": {
      "maxDuration": 10
    }
  }
}
