{
  "name": "joeai",
  "version": "0.1.0",
  "private": true,
  "description": "LINE OA Sales Intelligence & Customer Payment Bot — Vercel monorepo",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --filter @joeai/web build",
    "dev": "pnpm --filter @joeai/web dev",
    "lint": "pnpm -r --parallel lint",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r --parallel test",
    "db:generate": "pnpm --filter @joeai/db generate",
    "db:migrate": "pnpm --filter @joeai/db migrate",
    "db:seed": "pnpm --filter @joeai/db seed",
    "db:studio": "pnpm --filter @joeai/db studio"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
