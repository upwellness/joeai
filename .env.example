# =========================================
# JoeAI environment variables (example)
# Copy to .env.local and fill in real values
#
# Production: set these in Vercel project → Settings → Environment Variables
# =========================================

# --- Database (Neon or Vercel Postgres) ---
# Pooled connection string for serverless functions
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- LINE Messaging API ---
# Get from https://developers.line.biz/console/
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- QStash (Upstash) — HTTP-based queue ---
# Get from https://console.upstash.com/qstash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- App base URL (used for QStash callback URLs) ---
# Local: http://localhost:3000  (use ngrok/cloudflared tunnel for QStash callbacks)
# Vercel: auto-derived from VERCEL_URL, or set manually for prod
APP_BASE_URL=http://localhost:3000

# --- Cloudflare R2 (media + statement storage) ---
# Free tier: 10 GB storage, 0 egress fees, S3-compatible.
# Get from: https://dash.cloudflare.com/ → R2 → "Manage R2 API Tokens"
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=joeai-media
# Either R2's public dev URL (settings → R2.dev subdomain) or a custom domain
R2_PUBLIC_URL_BASE=https://pub-xxxx.r2.dev

# --- OCR provider ---
# Options: typhoon | google_vision | mock
OCR_PROVIDER=mock
GOOGLE_VISION_API_KEY=
TYPHOON_OCR_ENDPOINT=

# --- STT provider ---
# Options: whisper_local | google_stt | mock
STT_PROVIDER=mock
GOOGLE_STT_API_KEY=

# --- Auth ---
# Generate: openssl rand -hex 32
AUTH_SECRET=change-me-in-production
SESSION_COOKIE_NAME=joeai_session

# --- Slip matching thresholds ---
SLIP_AUTO_REPLY_CONFIDENCE_THRESHOLD=0.9
SLIP_REVIEW_CONFIDENCE_THRESHOLD=0.6

# --- Observability ---
LOG_LEVEL=info

# --- Local dev only: skip QStash signature verification ---
# Set to "1" when testing handlers without QStash signatures
DISABLE_QSTASH_VERIFY=
