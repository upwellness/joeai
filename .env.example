# =========================================
# JoeAI environment variables (example)
# Copy to .env and fill in real values
# =========================================

# --- Database ---
DATABASE_URL=postgresql://joeai:joeai@localhost:5432/joeai

# --- Redis (queue + cache) ---
REDIS_URL=redis://localhost:6379

# --- S3 / MinIO (media storage) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_MEDIA=joeai-media
S3_BUCKET_STATEMENTS=joeai-statements
S3_FORCE_PATH_STYLE=true

# --- LINE Messaging API ---
# Get these from https://developers.line.biz/console/
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- OCR provider ---
# Options: typhoon | google_vision | mock
OCR_PROVIDER=mock
GOOGLE_VISION_API_KEY=
TYPHOON_OCR_ENDPOINT=

# --- STT provider ---
# Options: whisper_local | google_stt | mock
STT_PROVIDER=mock
WHISPER_BIN=whisper
GOOGLE_STT_API_KEY=

# --- App config ---
WEBHOOK_PORT=3001
API_PORT=3002
WEB_PORT=3000
NODE_ENV=development

# --- Auth ---
# Generate: openssl rand -hex 32
AUTH_SECRET=change-me-in-production
SESSION_COOKIE_NAME=joeai_session

# --- Slip matching ---
SLIP_AUTO_REPLY_CONFIDENCE_THRESHOLD=0.9
SLIP_REVIEW_CONFIDENCE_THRESHOLD=0.6

# --- Observability ---
LOG_LEVEL=info
